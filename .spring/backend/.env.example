# Template for the Twenty backend stack.
#
# The runbook copies this to `.env` on first run. APP_SECRET and
# ENCRYPTION_KEY are hardcoded dev-only values committed to the repo —
# intentional, so every clone of the fork drives the shared `twenty-backend`
# compose project with the same secrets and the persistent DB volume stays
# decryptable across clones. **Do not use these values for any deployment
# anyone else can reach.**

# Docker image tag for twenty-server / twenty-worker.
# Pinned to a fixed version, NOT `latest`: `latest` is a moving tag that nothing
# in the runbook re-pulls, so every clone drifted to whatever it happened to
# cache — the "stale dev backend" failures. v2.10.0 is what this runbook was
# authored against (2026-06-08). Bump deliberately; wipe volumes when you do
# (`docker compose down -v`) so the DB isn't ahead of the pinned server.
TWENTY_TAG=v2.10.0

# URL the server advertises to clients (the host-running frontend hits this).
SERVER_URL=http://localhost:3000

# Postgres credentials. The frontend never talks to Postgres directly; these
# only matter to the server/worker containers.
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=default

# Dev-only secrets — base64, 32 random bytes each. Stable across clones so
# the Postgres volume keeps decoding the rows it sealed last time.
APP_SECRET=69+tcbouUoxhTzaCCO9GOMZ03XmvSBAMfwX2hypQs1o=
ENCRYPTION_KEY=YMaAQwlZwtXWIvxIN9cdMjP8amb78Y38lqk+zQ06Yko=
