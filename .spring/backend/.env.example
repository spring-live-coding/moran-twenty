# Template for the Twenty backend stack.
#
# The runbook copies this to `.env` on first run and fills in random values
# for APP_SECRET and ENCRYPTION_KEY. Re-running the runbook does NOT overwrite
# an existing `.env`, so generated secrets stay stable across runs (which is
# required — rotating ENCRYPTION_KEY invalidates data encrypted with the old
# one).

# Docker image tag for twenty-server / twenty-worker.
TWENTY_TAG=latest

# URL the server advertises to clients (the host-running frontend hits this).
SERVER_URL=http://localhost:3000

# Postgres credentials. The frontend never talks to Postgres directly; these
# only matter to the server/worker containers.
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=default

# Secrets — the runbook fills these in on first run.
APP_SECRET=
ENCRYPTION_KEY=
